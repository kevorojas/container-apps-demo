# Variables de entorno de referencia para la app demo DocSafe.
# En docker-compose ya vienen seteadas en docker-compose.yml; este archivo
# documenta qué usa cada servicio y sirve para correr los servicios sueltos.

# ---- web (frontend / BFF) --------------------------------------------
# URL interna del backend `api`. El web SÓLO habla con el api.
API_URL=http://api:8000

# ---- api (backend interno) -------------------------------------------
PROCESSOR_URL=http://processor:8000
CATALOG_URL=http://catalog:8000

# ---- processor (validación + storage) --------------------------------
# Modo de storage: 'azurite' (local, con connection string) o
# 'managed_identity' (Azure, sin secretos, vía DefaultAzureCredential).
STORAGE_MODE=azurite
STORAGE_CONTAINER=documents
MAX_SIZE_BYTES=10485760

# Sólo para STORAGE_MODE=azurite. Connection string de desarrollo del emulador
# Azurite. La cuenta/clave de Azurite son públicas y fijas, pero NO se incluyen
# en el repo para no disparar secret scanners. Copiá este archivo a `.env` y
# pegá la connection string de desarrollo desde la doc oficial de Microsoft:
#   https://learn.microsoft.com/en-us/azure/storage/common/storage-connect-azurite?tabs=blob-storage
# IMPORTANTE: en docker-compose el BlobEndpoint tiene que apuntar al host
# `azurite` (no a 127.0.0.1), así:
#   ...;BlobEndpoint=http://azurite:10000/devstoreaccount1;
AZURITE_CONNECTION_STRING=

# Sólo para STORAGE_MODE=managed_identity (producción en Azure).
# Endpoint de la cuenta de storage. NO se usa connection string acá:
# la credencial la provee la managed identity del Container App.
# STORAGE_ACCOUNT_URL=https://<cuenta>.blob.core.windows.net

# ---- catalog (índice/metadata) ---------------------------------------
CATALOG_DB_PATH=/data/catalog.db
